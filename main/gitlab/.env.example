# Copy to .env and fill in real values before running docker compose up.
# This file is safe to commit; .env is gitignored.

# ── GitLab ───────────────────────────────────────────────────────────────
# The public domain for your GitLab instance.
# Must have an A record pointing at your server's public IP.
GITLAB_DOMAIN=gitlab.example.com

# Initial password for the GitLab root (admin) account.
# Change immediately after first login.
GITLAB_ROOT_PASSWORD=changeme

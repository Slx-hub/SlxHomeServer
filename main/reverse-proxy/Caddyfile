# Wildcard certificate covers *.slakxs.de and slakxs.de
# All blocks share the same cert

slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem

    # Root redirect
    redir / /page 301

    ######################## Public pages ########################
    handle /page* {
        uri strip_prefix /page
        reverse_proxy mainpage:50000
    }

    # Authentication endpoint - always accessible
    handle /cookie* {
        reverse_proxy auth:49999
    }

    ######################## Private pages ########################
    # Everything under /secret requires authentication
    @hasAuth {
        header Cookie *auth_session*
    }

    # /secret/page - secret page
    handle /secret/page* {
        handle @hasAuth {
            uri strip_prefix /secret/page
            reverse_proxy secret-page:50002
        }
        handle {
            error 404
        }
    }

    # /secret/containers - container manager
    handle /secret/containers* {
        handle @hasAuth {
            uri strip_prefix /secret/containers
            reverse_proxy container-manager:50001
        }
        handle {
            error 404
        }
    }

    # Catch-all for any other paths
    handle {
        error 404
    }
}

# Redirect www.slakxs.de to slakxs.de
www.slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem
    redir https://slakxs.de{uri} 301
}

# Gitea — private git hosting
git.slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem

    @hasAuth {
        header Cookie *auth_session*
    }

    # Auth endpoint - always accessible; sets a host-only cookie for git.slakxs.de
    handle /cookie* {
        reverse_proxy auth:49999
    }

    handle @hasAuth {
        reverse_proxy gitea:3000
    }

    handle {
        error 404
    }
}

# Wildcard certificate covers *.slakxs.de and slakxs.de
# All blocks share the same cert

# Main site - served from page.slakxs.de subdomain
page.slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem
    
    # Route all requests to webpage service
    reverse_proxy webpage:50000
}

# Legacy domain - keep slakxs.de for backward compatibility
slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem

    # Redirect root to main site
    redir / https://page.slakxs.de 301

    # Authentication endpoint - always accessible
    handle /cookie* {
        reverse_proxy auth:49999
    }

    # Secret page - requires authentication or localhost access
    handle /secret* {
        @hasAuth {
            header Cookie *auth_session*
        }
        handle @hasAuth {
            uri strip_prefix /secret
            reverse_proxy secret-page:50001
        }

        # No auth and not local - hide the page
        handle {
            error 404
        }
    }

    # Catch-all for any other paths
    handle {
        error 404
    }
}

# Redirect www.slakxs.de to page.slakxs.de
www.slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem
    redir https://page.slakxs.de{uri} 301
}

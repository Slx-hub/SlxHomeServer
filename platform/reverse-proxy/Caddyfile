# Wildcard certificate covers *.slakxs.de and slakxs.de
# All blocks share the same cert

# Shared snippet — import this in any block that needs a login endpoint.
# The auth cookie is set for .slakxs.de so logging in from any subdomain
# grants access across the whole domain.
(cookie) {
    handle /cookie* {
        reverse_proxy auth:49999
    }
}


# Redirect www.slakxs.de to slakxs.de
www.slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem
    redir https://slakxs.de{uri} 301
}

slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem

    # Root redirect
    redir / /page 301

    ######################## Public pages ########################
    handle /page* {
        uri strip_prefix /page
        reverse_proxy mainpage:50000
    }

    # Authentication endpoint - always accessible
    import cookie

    ######################## Private pages ########################
    # forward_auth asks the auth service to validate the session cookie and
    # required role. /verify returns 404 on failure so unauthenticated users
    # get a silent 404 with no login hint.

    handle /secret* {
        forward_auth auth:49999 {
            uri /verify?role=admin
        }
        uri strip_prefix /secret
        reverse_proxy secret-page:50002
    }

    handle /containers* {
        forward_auth auth:49999 {
            uri /verify?role=admin
        }
        uri strip_prefix /containers
        reverse_proxy container-manager:50001
    }

    # Catch-all for any other paths
    handle {
        error 404
    }
}

# Beszel — resource monitor (dedicated subdomain avoids subpath asset issues)
monitor.slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem

    import cookie

    handle {
        forward_auth auth:49999 {
            uri /verify?role=dev
        }
        reverse_proxy beszel:8090
    }
}

# Stoat — self-hosted chat (requires guest role or above to reach /login)
stoat.slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem

    import cookie

    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }

    handle @websocket {
        reverse_proxy stoat:80
    }
    
    handle {
        forward_auth auth:49999 {
            uri /verify?role=guest
        }
        reverse_proxy stoat:80
    }
}

ntfy.slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem

    import cookie

    reverse_proxy ntfy:80
}

# Gitea — private git hosting
git.slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem

    import cookie

    handle {
        forward_auth auth:49999 {
            uri /verify?role=dev
        }
        reverse_proxy gitea:3000
    }
}

# Jellyfin — media server (host-networked, reached via host gateway)
jelly.slakxs.de {
    tls /etc/caddy/certs/certbot/fullchain1.pem /etc/caddy/certs/certbot/privkey1.pem

    import cookie

    # WebSocket upgrades bypass the cookie gate — Jellyfin's own token
    # auth still applies, and the client can only reach this point after
    # the initial HTTP auth check has already passed in the browser session.
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }

    handle @websocket {
        reverse_proxy host.docker.internal:8096
    }

    handle {
        forward_auth auth:49999 {
            uri /verify?role=guest
        }
        reverse_proxy host.docker.internal:8096
    }
}

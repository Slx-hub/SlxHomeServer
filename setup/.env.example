# SlxHomeServer Setup - Environment Variables
# Copy this file to ".env" and fill in your values.
# .env is gitignored and will NOT be committed.

# Wi-Fi credentials (used during unattended Debian install)
WIFI_SSID=MyNetwork
WIFI_PASSWORD=MySecretPassword

# Path to your SSH public key (used to authorize key-based SSH access)
SSH_PUBLIC_KEY_PATH=C:\Users\slx\.ssh\id_rsa.pub

# SlxHomeServer — Central Environment Configuration (Example)
# Copy this file to .env and fill in your values.
# .env is gitignored and will NOT be committed.

# ── Porkbun ──────────────────────────────────────────────────────────────────
# API credentials shared by the DDNS updater and Certbot.
# Get them at: https://porkbun.com/account/api
PORKBUN_API_KEY=your_api_key_here
PORKBUN_API_SECRET=your_api_secret_here

# ── Certbot ───────────────────────────────────────────────────────────────────
# Email for Let's Encrypt expiry notifications.
CERTBOT_EMAIL=your-email@example.com

# ── Reverse Proxy / Auth ──────────────────────────────────────────────────────
# Login tokens for the auth service. One per role; defines who can log in and
# what they can access. Role hierarchy (most to least privileged): admin > guest
# Add new roles by adding AUTH_TOKEN_<ROLE> and updating ROLE_HIERARCHY in
# platform/auth/app.py. Generate tokens with: openssl rand -hex 32
AUTH_TOKEN_ADMIN=your_secure_admin_token_here
AUTH_TOKEN_DEV=your_secure_dev_token_here
AUTH_TOKEN_GUEST=your_secure_guest_token_here

# ── Gitea ─────────────────────────────────────────────────────────────────────
# Public domain for the Gitea instance (must have an A record pointing here).
GITEA_DOMAIN=git.slakxs.de

# ── Backup ────────────────────────────────────────────────────────────────────
# Block device for the backup drive, identified by UUID so it survives renames.
# Find the UUID with: blkid /dev/sdX
BACKUP_DEVICE=/dev/disk/by-uuid/YOUR-UUID-HERE

# ── ntfy push notifications ────────────────────────────────────────────────────
# regenerate hash with: docker run --rm python:3.12-alpine sh -c 'pip install bcrypt -q && python3 -c "import bcrypt; print(bcrypt.hashpw(b\"<pw>\", bcrypt.gensalt(10)).decode())"’
NTFY_AUTH_USERS='user:hash:role'
NTFY_WEB_PUSH_PUBLIC_KEY=
NTFY_WEB_PUSH_PRIVATE_KEY=
NTFY_WEB_PUSH_EMAIL_ADDRESS=your-email@example.com

# ── Beszel monitoring ─────────────────────────────────────────────────────────
# SSH public key provided by the Beszel hub when you add this server as a system.
# Generated automatically by: bash apps/pages/monitoring/setup.sh
BESZEL_AGENT_KEY=
# Per-system WebSocket token shown in the hub's Add System dialog (fingerprints.token).
BESZEL_AGENT_TOKEN=

# ── Setup / Install ───────────────────────────────────────────────────────────
# Used by the preseed installer and Prepare-FlashDrive.ps1.
WIFI_SSID=MyNetwork
WIFI_PASSWORD=MySecretPassword
# Path to your SSH public key on the machine running the flash-drive script.
SSH_PUBLIC_KEY_PATH=C:\Users\slx\.ssh\id_rsa.pub

# Trip Planner chat assistant — copy to `.env` (same dir) and fill in.
# docker compose auto-loads `.env`. Keep the real .env out of git.

# Free Gemini API key from Google AI Studio (no credit card):
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model to use. Must be a current free-tier model — the 2.5-* models were
# pulled for new keys in July 2026. Good free options:
#   gemini-3.5-flash        current flash, 1500 requests/day free  (default)
#   gemini-3.1-flash-lite   lighter/faster, ~1000/day free
#   gemini-flash-latest     alias that auto-tracks the latest flash (avoids
#                           future deprecations, but its limit may change)
GEMINI_MODEL=gemini-3.5-flash

# Optional: Google Maps Platform key for geocoding. When set, Google Places
# becomes the authoritative geocoder — it matches maps.google.com and resolves
# venues by NAME (e.g. "Villa Fontaine Grand Tokyo Ariake"), which the keyless
# OSM services (Nominatim/Photon) place a block off or miss entirely. Leave it
# blank to stay fully keyless (pins just geocode less accurately).
#   1. https://console.cloud.google.com/  → create/select a project
#   2. Enable "Places API (New)"  (needs a billing account, but personal-trip
#      volume sits well inside the free monthly credit)
#   3. APIs & Services → Credentials → create an API key; restrict it to the
#      Places API. Paste it below.
GOOGLE_MAPS_API_KEY=

# The chat meter shows % of this daily request quota remaining (resets at
# midnight US Pacific, like Gemini's real free-tier reset). Set it to your
# model's real free-tier requests-per-day: gemini-3.5-flash = 1500.
CHAT_DAILY_LIMIT=1500

# Assistant transcript log — a rolling daily record of every chat turn (the
# user message, the model's thinking, each tool call + arguments, each tool
# result, and the final reply), written to ./logs/chat.log (git-ignored).
#   CHAT_LOG_LEVEL     INFO (the transcript) or DEBUG (also logs the full
#                      system prompt + context block sent to the model).
#   CHAT_LOG_KEEP_DAYS how many daily log files to keep (rotates at midnight).
CHAT_LOG_LEVEL=INFO
CHAT_LOG_KEEP_DAYS=5

# Trip Planner chat assistant — copy to `.env` (same dir) and fill in.
# docker compose auto-loads `.env`. Keep the real .env out of git.

# Free Gemini API key from Google AI Studio (no credit card):
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model to use. Must be a current free-tier model — the 2.5-* models were
# pulled for new keys in July 2026. Good free options:
#   gemini-3.5-flash        current flash, 1500 requests/day free  (default)
#   gemini-3.1-flash-lite   lighter/faster, ~1000/day free
#   gemini-flash-latest     alias that auto-tracks the latest flash (avoids
#                           future deprecations, but its limit may change)
GEMINI_MODEL=gemini-3.5-flash

# The chat meter shows % of this daily request quota remaining (resets at
# midnight US Pacific, like Gemini's real free-tier reset). Set it to your
# model's real free-tier requests-per-day: gemini-3.5-flash = 1500.
CHAT_DAILY_LIMIT=1500

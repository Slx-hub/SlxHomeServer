# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# DO NOT commit .env — it contains your Gitea registration token.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gitea ─────────────────────────────────────────────────────────────────────

# Registration token for this runner.
# Gitea → repo → Settings → Actions → Runners → Create new runner
GITEA_RUNNER_REGISTRATION_TOKEN=D0gvfu2iHfUjNqCYVljVyRV14fISpJxxxxxxxxxx

# URL of your Gitea instance reachable from inside this container.
#
# If Gitea is on the same Docker host, common options are:
#   http://172.17.0.1:3000        — Linux Docker bridge gateway (default subnet)
#   http://host.docker.internal:3000 — Docker Desktop (Mac / Win)
#   http://gitea:3000             — shared Docker network (uncomment networks: in compose)
#
# If Gitea is behind a reverse proxy, use the public URL.
GITEA_INSTANCE_URL=http://gitea:3000

# ── Unity ─────────────────────────────────────────────────────────────────────

# Unity version — must match a tag published on hub.docker.com/r/unityci/editor
# Check existing tags at: https://hub.docker.com/r/unityci/editor/tags
# and adjust GAMECI_SCHEMA if the major-version tag (e.g. "3") doesn't exist.
UNITY_VERSION=6000.3.10f1
GAMECI_SCHEMA=3

# ── Runner identity (optional) ───────────────────────────────────────────────

# Displayed name in Gitea's runner list.
GITEA_RUNNER_NAME=unity-runner

# Labels the runner advertises. "unity-linux:host" tells act_runner to run jobs
# directly inside this container instead of spawning additional Docker containers.
# Must include the labels referenced in the workflow's runs-on: [...] array.
GITEA_RUNNER_LABELS=self-hosted,unity-linux:host